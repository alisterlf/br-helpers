{
  "name": "br-helpers",
  "version": "3.1.2",
  "description": "Helpers para validar, formatar e analisar CPF, CNPJ, CEP, telefone e outros identificadores brasileiros.",
  "keywords": [
    "cpf",
    "cnpj",
    "cep",
    "phone",
    "validator",
    "formatter",
    "TypeScript"
  ],
  "homepage": "https://github.com/alisterlf/br-helpers#readme",
  "bugs": {
    "url": "https://github.com/alisterlf/br-helpers/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alisterlf/br-helpers.git"
  },
  "license": "MIT",
  "author": "Álister Lopes Ferreira",
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/esm/index.mjs",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./cep": {
      "types": "./dist/cep.d.ts",
      "import": "./dist/esm/cep.mjs",
      "require": "./dist/cep.js",
      "default": "./dist/cep.js"
    },
    "./cnpj": {
      "types": "./dist/cnpj.d.ts",
      "import": "./dist/esm/cnpj.mjs",
      "require": "./dist/cnpj.js",
      "default": "./dist/cnpj.js"
    },
    "./cpf": {
      "types": "./dist/cpf.d.ts",
      "import": "./dist/esm/cpf.mjs",
      "require": "./dist/cpf.js",
      "default": "./dist/cpf.js"
    },
    "./identifiers": {
      "types": "./dist/identifiers.d.ts",
      "import": "./dist/esm/identifiers.mjs",
      "require": "./dist/identifiers.js",
      "default": "./dist/identifiers.js"
    },
    "./phone": {
      "types": "./dist/phone.d.ts",
      "import": "./dist/esm/phone.mjs",
      "require": "./dist/phone.js",
      "default": "./dist/phone.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "br-helpers": "bin/br-helpers"
  },
  "typesVersions": {
    "*": {
      "cep": [
        "dist/cep.d.ts"
      ],
      "cnpj": [
        "dist/cnpj.d.ts"
      ],
      "cpf": [
        "dist/cpf.d.ts"
      ],
      "identifiers": [
        "dist/identifiers.d.ts"
      ],
      "phone": [
        "dist/phone.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "License.md",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf ./dist",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "build:js": "node ./scripts/build.js",
    "build:types": "tsc --project tsconfig.build.json",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepack": "npm run build",
    "prepublishOnly": "npm run lint && npm test",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "npm run test:coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "yargs": "^18.0.0"
  }
}
