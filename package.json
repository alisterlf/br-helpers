{
  "name": "br-helpers",
  "version": "2.0.0",
  "description": "Helpers para validar, formatar e analisar CPF, CNPJ, CEP, telefone e outros identificadores brasileiros.",
  "keywords": [
    "cpf",
    "cnpj",
    "cep",
    "phone",
    "validator",
    "formatter",
    "TypeScript"
  ],
  "homepage": "https://github.com/alisterlf/br-helpers#readme",
  "bugs": {
    "url": "https://github.com/alisterlf/br-helpers/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alisterlf/br-helpers.git"
  },
  "license": "MIT",
  "author": "Álister Lopes Ferreira",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "/dist",
    "License.md",
    "README.md"
  ],
  "scripts": {
    "prebuild": "rimraf ./dist",
    "prepublishOnly": "npm run build",
    "build": "tsc --project tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "npm run test:coverage",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
